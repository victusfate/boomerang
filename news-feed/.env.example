# Unified platform worker — covers all domains (rss, sync, meta, rec).
# Local dev: cd platform-worker && npm run dev  (or: make worker-platform)
# VITE_PLATFORM_WORKER_URL=https://boomerang-platform.boomerang.workers.dev
VITE_PLATFORM_WORKER_URL=http://127.0.0.1:8791

# Production: set VITE_PLATFORM_WORKER_URL as a repository variable in GitHub Actions.
# GitHub Actions: VITE_PLATFORM_WORKER_URL=https://boomerang-platform.<account>.workers.dev

# Legacy individual worker URLs — only needed if NOT using platform-worker.
# Uncomment and set these only when running the four separate legacy workers.
# VITE_RSS_WORKER_URL=http://127.0.0.1:8787
# VITE_SYNC_WORKER_URL=http://127.0.0.1:8788
# VITE_META_WORKER_URL=http://127.0.0.1:8789
# VITE_REC_WORKER_URL=http://127.0.0.1:8790

# Optional: `[sync:*]` console traces (`VITE_DEBUG_SYNC=true` or `localStorage.setItem('debug.sync','true')`).
# VITE_DEBUG_SYNC=true
