# Unified platform worker URL — covers all domains (rss, sync, meta, rec).
# When set, VITE_PLATFORM_WORKER_URL takes priority over individual VITE_*_WORKER_URL vars.
# Production: set only this one var (and optionally individual vars as fallback).
# VITE_PLATFORM_WORKER_URL=https://boomerang-platform.boomerang.workers.dev

# Individual worker URLs (legacy / fallback when VITE_PLATFORM_WORKER_URL is not set):
# VITE_RSS_WORKER_URL=https://boomerang-rss.boomerang.workers.dev
# VITE_SYNC_WORKER_URL=https://boomerang-sync.boomerang.workers.dev
# VITE_META_WORKER_URL=https://boomerang-meta.boomerang.workers.dev
# VITE_REC_WORKER_URL=https://boomerang-rec.boomerang.workers.dev
# GitHub Actions: set VITE_PLATFORM_WORKER_URL (or individual vars) as repository variables.

# Local dev — use distinct ports so multiple `wrangler dev` processes can run at once.
# Option A: unified platform-worker (recommended after consolidation):
#   platform-worker: 8791  |  make worker-platform  or  cd platform-worker && npm run dev
# VITE_PLATFORM_WORKER_URL=http://127.0.0.1:8791

# Option B: individual legacy workers (backwards-compat):
#   rss-worker:  8787  |  make worker-rss   or  cd rss-worker && npm run dev
#   sync-worker: 8788  |  make worker-sync  or  cd sync-worker && npm run dev
#   meta-worker: 8789  |  make worker-meta  or  cd meta-worker && npm run dev
#   rec-worker:  8790  |  make worker-rec   or  cd rec-worker && npm run dev
VITE_RSS_WORKER_URL=http://127.0.0.1:8787
VITE_SYNC_WORKER_URL=http://127.0.0.1:8788
VITE_META_WORKER_URL=http://127.0.0.1:8789
VITE_REC_WORKER_URL=http://127.0.0.1:8790

# Optional: `[sync:*]` console traces (`VITE_DEBUG_SYNC=true` or `localStorage.setItem('debug.sync','true')`).
# VITE_DEBUG_SYNC=true
