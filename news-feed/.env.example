# Cloudflare Worker (GET /bundle). No trailing slash.
# Account workers.dev subdomain: https://boomerang.workers.dev — the Worker URL is:
#   https://<wrangler-name>.boomerang.workers.dev   (see rss-worker/wrangler.jsonc "name")
VITE_RSS_WORKER_URL=https://boomerang-rss.boomerang.workers.dev

# Local dev (run `npm run dev` in rss-worker) instead of production:
# VITE_RSS_WORKER_URL=http://127.0.0.1:8787
