# Unified platform worker — covers all domains (rss, sync, meta, rec, capture).
# Local dev: cd platform-worker && npm run dev  (or: make worker-platform)
# VITE_PLATFORM_WORKER_URL=https://api.boomerang-news.com
VITE_PLATFORM_WORKER_URL=http://localhost:8787

# Production: set VITE_PLATFORM_WORKER_URL as a repository variable in GitHub Actions.
# First-party custom domain (see platform-worker/wrangler.jsonc routes):
# GitHub Actions: VITE_PLATFORM_WORKER_URL=https://api.boomerang-news.com

# Optional: `[sync:*]` console traces (`VITE_DEBUG_SYNC=true` or `localStorage.setItem('debug.sync','true')`).
# VITE_DEBUG_SYNC=true
