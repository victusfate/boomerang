# Cloudflare Worker (GET /bundle). No trailing slash.
# Account workers.dev subdomain: https://boomerang.workers.dev — the Worker URL is:
#   https://<wrangler-name>.boomerang.workers.dev   (see rss-worker/wrangler.jsonc "name")
# VITE_RSS_WORKER_URL=https://boomerang-rss.boomerang.workers.dev
# VITE_SYNC_WORKER_URL=https://boomerang-sync.boomerang.workers.dev
# VITE_META_WORKER_URL=https://boomerang-meta.boomerang.workers.dev
# All three are required at build time (and for local `npm run dev`). There are no baked-in production URLs.
#
# GitHub Actions: set repository variables VITE_RSS_WORKER_URL, VITE_SYNC_WORKER_URL, and VITE_META_WORKER_URL
# (no trailing slashes) on the repo that runs `.github/workflows/deploy.yml`.

# Local dev — use distinct ports so three `wrangler dev` processes can run at once:
#   rss-worker:   8787 (wrangler default)    |  make worker-rss
#   meta-worker:  8788                       |  make worker-meta
#   sync-worker:  8789 — run:  cd sync-worker && npx wrangler dev --port 8789
VITE_RSS_WORKER_URL=http://127.0.0.1:8787
VITE_SYNC_WORKER_URL=http://127.0.0.1:8788
VITE_META_WORKER_URL=http://127.0.0.1:8789
