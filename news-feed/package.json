{
  "name": "boomerang-news",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "build:gh-pages": "node scripts/generate-icons.mjs && npm run typecheck && cross-env GITHUB_PAGES=true vite build",
    "preview:gh-pages": "npm run build:gh-pages && cross-env GITHUB_PAGES=true vite preview"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "use-fireproof": "0.24.19"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "vite": "8.0.8",
    "magic-string": "0.30.21",
    "workbox-build": {
      "glob": "13.0.6",
      "source-map": "0.7.6"
    }
  }
}
