{
  "name": "boomerang-meta",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-09",
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    { "binding": "ARTICLE_META", "id": "00000000000000000000000000000001" }
  ],
  "durable_objects": {
    "bindings": [{ "name": "META_DO", "class_name": "MetaDO" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["MetaDO"] }]
}
